// generator client {
//   provider = "prisma-client"
//   output   = "../src/generated/prisma"
// }
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String

  // Current live location
  location LiveLocation?

  // Share sessions created by this user
  createdSessions ShareSession[] @relation("SessionCreator")

  // Sessions joined by this user
  sessionParticipants SessionParticipant[]

  // Emergency history
  emergencies Emergency[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LiveLocation {
  id        String   @id @default(cuid())
  latitude  Float
  longitude Float
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt
}

model ShareSession {
  id           String               @id @default(cuid())
  shareCode    String               @unique
  creatorId    String
  creator      User                 @relation("SessionCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  isActive     Boolean              @default(true)
  expiresAt    DateTime?
  participants SessionParticipant[]
  createdAt    DateTime             @default(now())
}

model SessionParticipant {
  id        String       @id @default(cuid())
  sessionId String
  userId    String
  session   ShareSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime     @default(now())

  @@unique([sessionId, userId])
}

model Emergency {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  latitude  Float
  longitude Float
  message   String?
  status    EmergencyStatus @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

enum EmergencyStatus {
  ACTIVE
  RESPONDING
  RESOLVED
}
