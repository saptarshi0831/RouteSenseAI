# ----------------------------------------------------------------------
# FULL-STACK MONOREPO .GITIGNORE
# ----------------------------------------------------------------------

# 1. Dependencies
node_modules/
/node_modules/
frontend/node_modules/
backend/node_modules/

# 2. Environment Variables & Secrets
# (CRITICAL: Never commit your API keys or database URLs)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*
!.env.example
*.pem

# 3. Build Outputs (Frontend & Backend)
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
*.tsbuildinfo
backend/dist/
frontend/dist/

# 4. Logs & Diagnostic files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log

# 5. Database & ORM (Prisma)
# Ignore local SQLite databases if you ever use them
*.db
*.sqlite
*.sqlite3
*.db-journal
# Ignore generated prisma client if placed outside node_modules
# (Usually not needed if generating into node_modules)

# 6. Testing & Coverage
coverage/
.nyc_output/

# 7. OS Generated Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# 8. Editor / IDE Specific Files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.vim

# 9. Project Specific (RouteSense AI Custom)
bugs/
userlogintest.txt
temp/
tmp/
scratch/
frontend/.env